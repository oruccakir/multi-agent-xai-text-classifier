\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces Turkish News: Confusion matrices for all 8 models. Classes: dunya, ekonomi, kultur, saglik, siyaset, spor, teknoloji. Decision Tree shows near-random predictions. All other models have a strong diagonal, especially for \textit  {spor}.}}{14}{}\protected@file@percent }
\newlabel{fig:trnews_cm}{{19}{14}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {20}{\ignorespaces Turkish News: Model performance comparison. Transformer leads at 93.8\%, followed by SVM (91.9\%) and Naive Bayes (89.9\%). The gap between the transformer and top classical models is slightly larger than on IMDB/AG~News, consistent with the small dataset and high class count.}}{14}{}\protected@file@percent }
\newlabel{fig:trnews_compare}{{20}{14}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {21}{\ignorespaces Turkish News: ROC-AUC curves (OvR per model). Transformer macro AUC=0.994, SVM and NB both $>$0.99. Decision Tree drops to 0.783. \textit  {Spor} is near-perfect for all models except Decision Tree.}}{15}{}\protected@file@percent }
