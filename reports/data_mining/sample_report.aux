\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces Turkish News: Confusion matrices for all 8 models. Classes: dunya, ekonomi, kultur, saglik, siyaset, spor, teknoloji. Decision Tree shows near-random predictions. All other models have a strong diagonal, especially for \textit  {spor}.}}{12}{}\protected@file@percent }
\newlabel{fig:trnews_cm}{{14}{12}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces Turkish News: Model performance comparison. Transformer leads at 93.8\%, followed by SVM (91.9\%) and Naive Bayes (89.9\%). The gap between the transformer and top classical models is slightly larger than on IMDB/AG~News, consistent with the small dataset and high class count.}}{12}{}\protected@file@percent }
