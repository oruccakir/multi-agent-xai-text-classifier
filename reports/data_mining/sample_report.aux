\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces AG News: Model performance comparison (Accuracy, F1-Macro, Precision, Recall). All models except Decision Tree score above 87\%. SVM and Logistic Regression are competitive with the transformer while being orders of magnitude faster.}}{8}{}\protected@file@percent }
\newlabel{fig:agnews_compare}{{8}{8}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces AG News: F1-Macro vs.\ F1-Weighted comparison. As with IMDB, the two metrics are nearly identical for all models, confirming that AG News is a well-balanced 4-class dataset ($\approx $30,000 samples per class). Decision Tree is the only model where Precision visibly exceeds Recall, indicating it over-predicts the majority-pattern classes while missing harder examples.}}{8}{}\protected@file@percent }
\newlabel{fig:agnews_f1}{{9}{8}{}{}{}}
\@writefile{toc}{\contentsline {section}{\numberline {VI}Discussion}{8}{}\protected@file@percent }
