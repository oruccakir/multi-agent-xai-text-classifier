\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Turkish Sentiment: Confusion matrices for all 8 models. Classes: negatif\,/\,notr\,/\,pozitif. The minority \textit  {negatif} class is consistently the hardest to classify correctly across all models.}}{10}{}\protected@file@percent }
\newlabel{fig:trsent_cm}{{10}{10}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Turkish Sentiment: Model performance comparison. The transformer leads on macro F1 (0.930), followed by SVM (0.877). All classical models suffer a visible gap between accuracy and F1-Macro due to the imbalanced negative class.}}{10}{}\protected@file@percent }
\newlabel{fig:trsent_compare}{{11}{10}{}{}{}}
