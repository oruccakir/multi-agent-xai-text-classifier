\newlabel{fig:imdb_time}{{6}{7}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces AG News: Confusion matrices for all 8 models. Classes: World (0) / Business (1) / Sports (2) / Sci\&Tech (3). Sports (Class~2) has the cleanest diagonal across all models. Decision Tree shows the most off-diagonal errors, especially between World and Business.}}{7}{}\protected@file@percent }
\newlabel{fig:agnews_cm}{{7}{7}{}{}{}}
