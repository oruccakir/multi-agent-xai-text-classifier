\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Turkish Sentiment: ROC-AUC curves (OvR per model). Transformer macro AUC=0.991. All models show lower AUC on \textit  {negatif} than on \textit  {pozitif}, consistent with the class imbalance.}}{11}{}\protected@file@percent }
